generator client {
  provider   = "prisma-client"
  output     = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Election {
  year        Int      @id
  total_ev    Int
  majority_ev Int

  election_candidates ElectionCandidate[]
  state_results       StateResult[]
}

model Candidate {
  id    Int    @id @default(autoincrement())
  name  String

  election_candidates ElectionCandidate[]
}

model ElectionCandidate {
  id            Int     @id @default(autoincrement())
  election_year Int
  candidate_id  Int
  role          String
  total_ev      Int
  is_winner     Boolean
  party         String
  election              Election               @relation(fields: [election_year], references: [year])
  candidate             Candidate              @relation(fields: [candidate_id], references: [id])
  state_result_candidates StateResultCandidate[]
}

model StateResult {
  id            Int    @id @default(autoincrement())
  election_year Int
  state_name    String
  total_ev      Int

  election                Election               @relation(fields: [election_year], references: [year])
  state_result_candidates StateResultCandidate[]
}

model StateResultCandidate {
  id                    Int @id @default(autoincrement())
  state_result_id       Int
  election_candidate_id Int
  ev_count              Int

  state_result       StateResult       @relation(fields: [state_result_id], references: [id])
  election_candidate ElectionCandidate @relation(fields: [election_candidate_id], references: [id])
}
